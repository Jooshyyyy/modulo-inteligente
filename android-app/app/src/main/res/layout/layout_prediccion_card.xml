<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#2A2A40"
    app:strokeColor="#6E56FF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Predicción de Gasto Hoy"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvPrediccionFecha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cargando..."
            android:textSize="14sp"
            android:textColor="#B0B0C0"
            android:layout_marginTop="4dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A1829"
            app:contentPadding="16dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                
                <TextView
                    android:id="@+id/tvPrediccionMonto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bs. --"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
                    
                <TextView
                    android:id="@+id/tvPrediccionNivel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#6E56FF"
                    android:background="#2A2A40"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tvPrediccionDiferencia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textSize="13sp"
                    android:textColor="#A0A0A0"
                    android:layout_marginTop="16dp"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/tvPrediccionSemaforo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="#2A2A40"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:text="Alerta IA: —"
                    android:textColor="#D0D0E0"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvProbabilidadesList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            tools:listitem="@layout/item_probabilidad_ia" />

        <Button
            android:id="@+id/btnCambiarFalsaFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="[Demo] Simular Día Siguiente"
            style="?android:attr/borderlessButtonStyle"
            android:textColor="#6E56FF"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
