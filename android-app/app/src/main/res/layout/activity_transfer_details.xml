<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1A237E"
        app:title="Comprobante de Transferencia"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/receiptContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_margin="16dp"
            android:background="@android:color/white"
            android:elevation="4dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@android:drawable/checkbox_on_background"
                app:tint="#4CAF50"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡Transferencia Exitosa!"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:layout_gravity="center"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:id="@+id/tvMonto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BOB 0.00"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#1A237E"
                android:layout_gravity="center"
                android:layout_marginBottom="32dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emisor"
                android:textColor="#757575"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvNombreOrigen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre Emisor"
                android:textSize="18sp"
                android:textColor="#212121"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cuenta de Origen"
                android:textColor="#757575"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvCuentaOrigen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0000000000"
                android:textSize="18sp"
                android:textColor="#212121"
                android:layout_marginBottom="16dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="24dp"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Destinatario"
                android:textColor="#757575"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvNombreDestino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textSize="18sp"
                android:textColor="#212121"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cuenta de Destino"
                android:textColor="#757575"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvCuentaDestino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0000000000"
                android:textSize="18sp"
                android:textColor="#212121"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Banco"
                android:textColor="#757575"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvBancoDestino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Banco Ejemplo"
                android:textSize="18sp"
                android:textColor="#212121"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Concepto"
                android:textColor="#757575"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvConcepto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---"
                android:textSize="18sp"
                android:textColor="#212121"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha y Hora"
                android:textColor="#757575"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01/01/2026 00:00"
                android:textSize="18sp"
                android:textColor="#212121"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@android:color/white">

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Volver"
            android:backgroundTint="#BDBDBD"
            android:textColor="#212121"
            android:layout_marginEnd="8dp"
            app:cornerRadius="8dp" />

        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Guardar"
            android:backgroundTint="#1A237E"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp"
            app:cornerRadius="8dp" />
    </LinearLayout>

</LinearLayout>
