<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ModuloInteligente" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_navy</item>
        <item name="colorPrimaryVariant">@color/primary_navy_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary_gold</item>
        <item name="colorSecondaryVariant">@color/secondary_gold_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- UI colors -->
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
</resources>